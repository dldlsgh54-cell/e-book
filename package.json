{
  "name": "ebook-creator-saas",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "dist": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "next": "^14.2.5",
    "openai": "^4.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.3",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.5",
    "typescript": "^5.5.4"
  },
  "build": {
    "appId": "com.startcoding.ebookcreator",
    "productName": "Ebook Creator",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
